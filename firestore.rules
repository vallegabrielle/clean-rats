rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções globais ────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    // ── /users/{userId} ────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if false;

      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['pushToken', 'updatedAt'])
        && request.resource.data.pushToken is string
        && request.resource.data.pushToken.size() > 0
        && request.resource.data.pushToken.size() <= 300
        && request.resource.data.updatedAt is string;

      allow delete: if isOwner(userId);
    }

    // ── /houses/{houseId} ─────────────────────────────────────────────────────

    match /houses/{houseId} {

      function isMember() {
        return isAuth() && request.auth.uid in resource.data.memberIds;
      }

      function isPending() {
        return isAuth()
          && request.auth.uid in resource.data.get('pendingMemberIds', []);
      }

      function isAddingSelfToPending() {
        let uid         = request.auth.uid;
        let incoming    = request.resource.data;
        let existing    = resource.data;
        let changed     = incoming.diff(existing).affectedKeys();
        let prevPending = existing.get('pendingMemberIds', []);
        let nextPending = incoming.pendingMemberIds;
        return changed.hasOnly(['pendingMemberIds', 'pendingRequests'])
          && nextPending.hasAll(prevPending)
          && nextPending.hasAny([uid])
          && incoming.get('pendingRequests', []).size() <= 50;
      }

      // CREATE: criador deve incluir apenas si mesmo.
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.keys().hasAll([
             'id', 'name', 'code', 'period', 'memberIds', 'members',
             'tasks', 'createdAt', 'periodStart', 'history'
           ])
        && isValidString(request.resource.data.name, 100)
        && isValidString(request.resource.data.code, 20)
        && request.resource.data.period in ['weekly', 'biweekly', 'monthly']
        && request.resource.data.memberIds is list
        && request.resource.data.members is list
        && request.resource.data.tasks is list
        && request.resource.data.history is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.members.size() == 1;

      allow get: if isMember() || isPending();

      // LIST necessário para onSnapshot where() e joinHouseByCode.
      // Mitigação de longo prazo: ativar App Check no Firebase Console e trocar para:
      //   allow list: if isAuth() && request.app != null;
      // Não ativar request.app != null antes de habilitar enforcement — quebra listeners.
      allow list: if isAuth();

      // UPDATE: membros atualizam livremente exceto id, code e createdAt (imutáveis).
      allow update: if
        (isMember()
          && request.resource.data.id == resource.data.id
          && request.resource.data.code == resource.data.code
          && request.resource.data.createdAt == resource.data.createdAt
        )
        || (isAuth() && isAddingSelfToPending());

      allow delete: if isMember();

      // ── /houses/{houseId}/logs/{logId} ──────────────────────────────────────
      // CORREÇÃO CRÍTICA: movido para DENTRO de /houses/{houseId}.
      // Dentro do bloco filho, `resource` aponta para o log — não para a toca.
      // Por isso isMemberOfHouse() usa get() explícito para ler os memberIds da toca.
      match /logs/{logId} {

        function isMemberOfHouse() {
          let house = get(/databases/$(database)/documents/houses/$(houseId));
          return isAuth() && request.auth.uid in house.data.memberIds;
        }

        allow read: if isMemberOfHouse();

        // O app envia { id, taskId, memberId, completedAt, createdAt: serverTimestamp() }.
        // createdAt é opcional (seedMockData não envia).
        allow create: if isMemberOfHouse()
          && request.resource.data.memberId == request.auth.uid
          && request.resource.data.keys().hasAll(['id', 'taskId', 'memberId', 'completedAt'])
          && request.resource.data.keys().hasOnly(['id', 'taskId', 'memberId', 'completedAt', 'createdAt'])
          && request.resource.data.id is string
          && request.resource.data.taskId is string
          && request.resource.data.memberId is string
          && request.resource.data.completedAt is string
          && request.resource.data.completedAt.size() > 0
          && request.resource.data.completedAt.size() <= 30;

        // Apenas taskId pode mudar. memberId é imutável (impede trocar autoria do log).
        allow update: if isMemberOfHouse()
          && resource.data.memberId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['taskId'])
          && request.resource.data.taskId is string
          && request.resource.data.taskId.size() > 0;

        // Qualquer membro pode deletar qualquer log da toca.
        // Necessário para resetPeriod e removeTask que deletam logs de todos os membros.
        allow delete: if isMemberOfHouse();
      }
    }

    // ── /rateLimits/{key} ─────────────────────────────────────────────────────
    // Exclusivo para Cloud Functions via Admin SDK.
    match /rateLimits/{key} {
      allow read, write: if false;
    }
  }
}
