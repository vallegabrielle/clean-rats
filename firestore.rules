rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /houses/{houseId} {

      // ── Helpers ───────────────────────────────────────────────────────────────

      function isAuth() {
        return request.auth != null;
      }

      // Full member of this house
      function isMember() {
        return isAuth() && request.auth.uid in resource.data.memberIds;
      }

      // User with a pending join request for this house
      function isPending() {
        return isAuth()
          && request.auth.uid in resource.data.get('pendingMemberIds', []);
      }

      // Non-member self-enrolling as pending.
      // Only 'pendingMemberIds' and 'pendingRequests' may change,
      // no existing entries may be removed, and the caller must be
      // added to pendingMemberIds.
      function isAddingSelfToPending() {
        let changed  = request.resource.data.diff(resource.data).affectedKeys();
        let uid      = request.auth.uid;
        let prevPending = resource.data.get('pendingMemberIds', []);
        let nextPending = request.resource.data.pendingMemberIds;
        return changed.hasOnly(['pendingMemberIds', 'pendingRequests'])
          && nextPending.hasAll(prevPending)   // cannot remove anyone
          && nextPending.hasAny([uid]);         // must add self
      }

      // ── Rules ─────────────────────────────────────────────────────────────────

      // CREATE — only the creator, who must include themselves as a member
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.memberIds;

      // GET — members and pending members only
      allow get: if isMember() || isPending();

      // LIST — required for:
      //   • onSnapshot where("memberIds", "array-contains", uid)
      //   • onSnapshot where("pendingMemberIds", "array-contains", uid)
      //   • joinHouseByCode  where("code", "==", code)
      //
      // App Check: once enforcement is active in Firebase Console → App Check →
      // Cloud Firestore → Enforce, replace the rule below with:
      //   allow list: if isAuth() && request.app != null;
      // WARNING: deploying that rule before enforcement is enabled breaks all
      // list queries (request.app is null when enforcement is off).
      allow list: if isAuth();

      // UPDATE — members can update freely;
      //          non-members may only add themselves as pending
      allow update: if isMember() || (isAuth() && isAddingSelfToPending());

      // DELETE — only a member (last member leaving destroys the house)
      allow delete: if isMember();
    }

    match /users/{userId} {
      // Only the owner can write their own push token document.
      // read: if false — tokens are only read server-side by Cloud Functions (Admin SDK bypasses rules).
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['pushToken', 'updatedAt'])
        && request.resource.data.pushToken is string;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow read: if false;
    }

    match /houses/{houseId}/logs/{logId} {
      function isMemberOfHouse() {
        return isAuth() && request.auth.uid in get(/databases/$(database)/documents/houses/$(houseId)).data.memberIds;
      }

      allow read: if isMemberOfHouse();
      allow create: if isMemberOfHouse()
        && request.resource.data.memberId == request.auth.uid
        && request.resource.data.keys().hasAll(['id', 'taskId', 'memberId', 'completedAt'])
        && request.resource.data.taskId is string
        && request.resource.data.completedAt is string;
      allow update: if isMemberOfHouse() && resource.data.memberId == request.auth.uid;
      allow delete: if isMemberOfHouse() && resource.data.memberId == request.auth.uid;
    }
  }
}
